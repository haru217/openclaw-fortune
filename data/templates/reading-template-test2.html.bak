  .mg .mg-num { color: #c9a84c; font-size: 18px; font-weight: 700; }
  .mg .mg-title { color: #c9a84c; font-size: 14px; font-weight: 700; }
  .mg p { font-size: 14px; line-height: 2.0; color: #d0d0d0; }
