  .act .an { color: #c9a84c; font-size: 13px; font-weight: 700; margin-bottom: 6px; }
  .act p { font-size: 14px; line-height: 2.0; color: #d0d0d0; }
  .mg { background: rgba(201,168,76,0.04); border: 1px solid rgba(201,168,76,0.12); border-radius: 8px; padding: 16px 18px; margin-bottom: 12px; }
